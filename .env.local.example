# Copy this file to .env.local and fill in your values
# Then add the same variables to your Vercel project settings

# Get a free API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address to send daily workout reminders to
USER_EMAIL=you@example.com

# The date Week A of the 3-week cycle begins (ISO format, must be a Monday)
CYCLE_START_DATE=2026-03-02

# OpenAI API key for the AI Coach feature (uses GPT-4o)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
